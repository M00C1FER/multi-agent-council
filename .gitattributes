# Prevent Windows-side checkouts from injecting CRLF that breaks WSL2 installers.
# Cross-platform install scripts (e.g. install.sh) must stay LF-only.
*.sh        text eol=lf
*.bash      text eol=lf
*.zsh       text eol=lf
install.sh  text eol=lf
*.py        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.md        text
*.png       binary
*.jpg       binary
*.gif       binary
